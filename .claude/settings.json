{
  "permissions": {
    "allow": [
      "Bash(pnpm *)",
      "Bash(node *)",
      "Bash(docker compose *)",
      "Bash(bash scripts/db/*)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Read(.env)",
      "Read(.env.*)"
    ]
  }
}
