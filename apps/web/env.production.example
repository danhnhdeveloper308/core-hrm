# ============================================================
# FRONTEND (apps/web) — biến môi trường PRODUCTION
# CHỈ biến NEXT_PUBLIC_* mới đến được trình duyệt. KHÔNG đặt secret ở đây.
# NEXT_PUBLIC_* được inline lúc BUILD → đổi giá trị phải BUILD lại (redeploy).
# ============================================================

# URL API backend (kèm prefix /api). FE gọi REST qua đây.
NEXT_PUBLIC_API_URL=https://your-api.up.railway.app/api
# URL WebSocket (Socket.IO) — thường là gốc backend, KHÔNG có /api.
NEXT_PUBLIC_WS_URL=https://your-api.up.railway.app
# URL public của chính FE.
NEXT_PUBLIC_APP_URL=https://your-frontend.vercel.app

# ----- FCM Web Push (tuỳ chọn — Firebase Console → Project settings) -----
# Thiếu cả cụm → app vẫn chạy in-app + native notification (tab khác) + email.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Cloud Messaging → Web Push certificates
NEXT_PUBLIC_FIREBASE_VAPID_KEY=
