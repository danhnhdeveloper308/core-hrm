generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BANNED
}

enum OAuthProvider {
  GOOGLE
}

enum VerificationType {
  EMAIL_VERIFY
  PASSWORD_RESET
  LOGIN_OTP
  INVITE
}

model User {
  id              String     @id @default(uuid()) @db.Uuid
  /// Luôn lưu lowercase — normalize ở zod schema trước khi vào DB
  email           String     @unique
  /// Null với user chỉ đăng nhập qua OAuth
  passwordHash    String?
  name            String
  avatarUrl       String?
  status          UserStatus @default(ACTIVE)
  emailVerifiedAt DateTime?
  /// TOTP secret đã mã hoá AES-256-GCM bằng TOTP_ENCRYPTION_KEY
  totpSecret      String?
  totpEnabled     Boolean    @default(false)
  /// Null = platform admin (không thuộc tenant nào)
  orgId           String?    @db.Uuid
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  org           Organization?  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  roles         UserRole[]
  sessions      Session[]
  devices       Device[]
  oauthAccounts OAuthAccount[]
  recoveryCodes RecoveryCode[]
  employee      Employee?

  @@index([orgId])
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  /// Role hệ thống (SUPER_ADMIN/ADMIN/USER) — không sửa tên, không xoá
  isSystem    Boolean  @default(false)
  /// Null = role platform; có giá trị = role nội bộ 1 org (ORG_ADMIN, HR_MANAGER...)
  orgId       String?  @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org         Organization?    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  users       UserRole[]

  @@unique([orgId, name])
  @@index([orgId])
}

model Permission {
  id          String  @id @default(uuid()) @db.Uuid
  /// Format `resource:action`, seed từ @repo/shared
  name        String  @unique
  description String?

  roles RolePermission[]
}

model RolePermission {
  roleId       String @db.Uuid
  permissionId String @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserRole {
  userId String @db.Uuid
  roleId String @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model Session {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  /// sha256(refresh token) — không bao giờ lưu raw token
  refreshTokenHash String    @unique
  deviceId         String?   @db.Uuid
  ip               String?
  userAgent        String?
  lastActiveAt     DateTime  @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?
  revokedReason    String?
  createdAt        DateTime  @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  device Device? @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model Device {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  /// sha256(userAgent + platform) — nhận diện lại thiết bị giữa các session
  fingerprint      String
  /// Tên thân thiện, vd "Chrome on macOS"
  name             String
  firstSeenAt      DateTime  @default(now())
  lastSeenAt       DateTime  @default(now())
  trusted          Boolean   @default(false)
  /// sha256(token trong cookie trusted_device) — "ghi nhớ thiết bị" skip 2FA
  trustedTokenHash String?
  trustedUntil     DateTime?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions Session[]

  @@unique([userId, fingerprint])
}

model OAuthAccount {
  id                String        @id @default(uuid()) @db.Uuid
  userId            String        @db.Uuid
  provider          OAuthProvider
  providerAccountId String
  email             String?
  createdAt         DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  id         String           @id @default(uuid()) @db.Uuid
  /// Email nhận OTP
  identifier String
  codeHash   String
  type       VerificationType
  expiresAt  DateTime
  consumedAt DateTime?
  /// Số lần nhập sai — quá 5 thì vô hiệu
  attempts   Int              @default(0)
  createdAt  DateTime         @default(now())

  @@index([identifier, type])
}

model RecoveryCode {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String?  @db.Uuid
  actorEmail String?
  /// Dạng `resource.action`, vd `user.update`
  action     String
  resource   String
  resourceId String?
  ip         String?
  userAgent  String?
  /// Diff/context — đã redact password|token|secret|otp trước khi ghi
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([actorId, createdAt(sort: Desc)])
  @@index([resource, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc), id])
}

// ============================================================
// HRM — Multi-tenant & cơ cấu tổ chức (Phase 1)
// ============================================================

enum OrgStatus {
  ACTIVE
  SUSPENDED
}

model Organization {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  slug      String    @unique
  status    OrgStatus @default(ACTIVE)
  timezone  String    @default("Asia/Ho_Chi_Minh")
  settings  Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  /// Ca mặc định toàn org — fallback cuối khi resolve ca
  defaultShiftId    String? @db.Uuid
  /// Lịch nghỉ lễ mặc định toàn org
  defaultCalendarId String? @db.Uuid

  defaultShift    WorkShift?       @relation("OrgDefaultShift", fields: [defaultShiftId], references: [id], onDelete: SetNull)
  defaultCalendar HolidayCalendar? @relation("OrgDefaultCalendar", fields: [defaultCalendarId], references: [id], onDelete: SetNull)

  users        User[]
  roles        Role[]
  orgUnitTypes OrgUnitType[]
  orgUnits     OrgUnit[]
  positions    Position[]
  worksites    Worksite[]
  employees    Employee[]
  contracts    EmploymentContract[]
  workShifts        WorkShift[]
  shiftAssignments  ShiftAssignment[]
  holidayCalendars  HolidayCalendar[]
  timesheetDays         TimesheetDay[]
  attendanceCorrections AttendanceCorrection[]
  faceProfiles          FaceProfile[]
}

/// Loại đơn vị trong cây tổ chức — mỗi org tự định nghĩa (TAP_DOAN, NHA_MAY...)
model OrgUnitType {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @db.Uuid
  code      String
  name      String
  /// Gợi ý thứ tự tầng cho UI + resolve approver — cây KHÔNG ép đúng rank
  rank      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  units OrgUnit[]

  @@unique([orgId, code])
}

model OrgUnit {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @db.Uuid
  parentId  String?  @db.Uuid
  typeId    String   @db.Uuid
  name      String
  code      String
  /// Materialized path "/rootId/.../selfId/" — query subtree bằng startsWith
  path      String
  /// Employee.id — FK gắn ở Phase 2 khi có model Employee
  managerId String?  @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parent   OrgUnit?     @relation("OrgUnitTree", fields: [parentId], references: [id], onDelete: Restrict)
  children OrgUnit[]    @relation("OrgUnitTree")
  type     OrgUnitType  @relation(fields: [typeId], references: [id], onDelete: Restrict)
  manager  Employee?    @relation("OrgUnitManager", fields: [managerId], references: [id], onDelete: SetNull)

  /// Cấu hình kế thừa theo cây — resolve leo lên cha gần nhất có giá trị
  defaultShiftId    String? @db.Uuid
  holidayCalendarId String? @db.Uuid

  defaultShift    WorkShift?       @relation("OrgUnitDefaultShift", fields: [defaultShiftId], references: [id], onDelete: SetNull)
  holidayCalendar HolidayCalendar? @relation("OrgUnitCalendar", fields: [holidayCalendarId], references: [id], onDelete: SetNull)

  employees Employee[] @relation("EmployeeOrgUnit")

  @@unique([orgId, parentId, code])
  @@index([orgId, path])
  @@index([parentId])
}

model Position {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @db.Uuid
  name      String
  code      String
  /// Cấp bậc chức danh (1 = thấp nhất). Dùng cho chính sách phép theo cấp + định tuyến duyệt.
  level     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employees Employee[]

  @@unique([orgId, code])
}

model Worksite {
  id              String   @id @default(uuid()) @db.Uuid
  orgId           String   @db.Uuid
  name            String
  address         String?
  lat             Float
  lng             Float
  radiusM         Int      @default(100)
  requireFace     Boolean  @default(false)
  requireLocation Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employees Employee[]

  @@index([orgId])
}

// ============================================================
// HRM — Employee management (Phase 2)
// ============================================================

enum EmployeeStatus {
  ACTIVE
  PROBATION
  INACTIVE
  TERMINATED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ContractType {
  PROBATION
  FIXED_TERM
  INDEFINITE
}

model Employee {
  id         String         @id @default(uuid()) @db.Uuid
  orgId      String         @db.Uuid
  /// 1-1 User — null khi hồ sơ chưa được mời tài khoản
  userId     String?        @unique @db.Uuid
  code       String
  fullName   String
  dob        DateTime?      @db.Date
  gender     Gender?
  phone      String?
  orgUnitId  String?        @db.Uuid
  positionId String?        @db.Uuid
  managerId  String?        @db.Uuid
  worksiteId String?        @db.Uuid
  joinDate   DateTime       @db.Date
  leaveDate  DateTime?      @db.Date
  status     EmployeeStatus @default(ACTIVE)
  avatarKey  String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user     User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  orgUnit  OrgUnit?     @relation("EmployeeOrgUnit", fields: [orgUnitId], references: [id], onDelete: SetNull)
  position Position?    @relation(fields: [positionId], references: [id], onDelete: SetNull)
  manager  Employee?    @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)
  reports  Employee[]   @relation("EmployeeManager")
  worksite Worksite?    @relation(fields: [worksiteId], references: [id], onDelete: SetNull)

  contracts        EmploymentContract[]
  managedUnits     OrgUnit[]            @relation("OrgUnitManager")
  shiftAssignments ShiftAssignment[]
  attendanceLogs        AttendanceLog[]
  timesheetDays         TimesheetDay[]
  attendanceCorrections AttendanceCorrection[]
  faceProfile           FaceProfile?

  @@unique([orgId, code])
  @@index([orgId, orgUnitId])
  @@index([orgId, status])
  @@index([managerId])
}

model EmploymentContract {
  id         String       @id @default(uuid()) @db.Uuid
  orgId      String       @db.Uuid
  employeeId String       @db.Uuid
  type       ContractType
  startDate  DateTime     @db.Date
  endDate    DateTime?    @db.Date
  /// Key file trên object storage — đọc qua signed URL
  fileKey    String?
  note       String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employee Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([orgId, employeeId])
}

// ============================================================
// HRM — Shifts, lịch làm việc & ngày lễ (Phase 3)
// ============================================================

model WorkShift {
  id               String   @id @default(uuid()) @db.Uuid
  orgId            String   @db.Uuid
  name             String
  /// "HH:mm" — giờ địa phương theo timezone của org
  startTime        String
  endTime          String
  /// Cửa sổ nghỉ trưa "HH:mm" — giờ công trừ phần giao với cửa sổ này.
  /// Null = dùng breakMinutes (trừ cứng) làm fallback.
  breakStart       String?
  breakEnd         String?
  breakMinutes     Int      @default(60)
  lateGraceMinutes Int      @default(5)
  otEnabled        Boolean  @default(false)
  /// Các thứ làm việc trong tuần: 1=Thứ 2 ... 7=Chủ nhật
  workDays         Int[]    @default([1, 2, 3, 4, 5])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  org             Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  assignments     ShiftAssignment[]
  defaultForUnits OrgUnit[]         @relation("OrgUnitDefaultShift")
  defaultForOrgs  Organization[]    @relation("OrgDefaultShift")

  @@index([orgId])
}

/// Lịch sử gán ca — ca áp dụng tại 1 ngày = bản ghi active gần nhất
model ShiftAssignment {
  id            String    @id @default(uuid()) @db.Uuid
  orgId         String    @db.Uuid
  employeeId    String    @db.Uuid
  shiftId       String    @db.Uuid
  effectiveFrom DateTime  @db.Date
  effectiveTo   DateTime? @db.Date
  createdAt     DateTime  @default(now())

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employee Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift    WorkShift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@index([employeeId, effectiveFrom(sort: Desc)])
  @@index([orgId])
}

model HolidayCalendar {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @db.Uuid
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org             Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  holidays        Holiday[]
  defaultForUnits OrgUnit[]      @relation("OrgUnitCalendar")
  defaultForOrgs  Organization[] @relation("OrgDefaultCalendar")

  @@index([orgId])
}

model Holiday {
  id         String   @id @default(uuid()) @db.Uuid
  calendarId String   @db.Uuid
  /// Khoảng nghỉ [startDate, endDate] — nghỉ 1 ngày thì 2 giá trị bằng nhau
  startDate  DateTime @db.Date
  endDate    DateTime @db.Date
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  calendar HolidayCalendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)

  @@index([calendarId, startDate, endDate])
}

// ============================================================
// HRM — Attendance core + Timesheet engine (Phase 4)
// ============================================================

enum AttendanceType {
  IN
  OUT
  UNKNOWN
}

enum AttendanceSource {
  FACE
  FINGERPRINT
  MANUAL
  WEB
}

enum TimesheetStatus {
  PRESENT
  LATE
  EARLY_LEAVE
  LATE_AND_EARLY
  ABSENT
  ON_LEAVE
  HALF_LEAVE
  HOLIDAY
  WEEKEND
  NOT_SCHEDULED
}

enum CorrectionStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

/// PARTITION BY RANGE(recordedAt) theo tháng — xem migration SQL thủ công.
/// PK + unique đều chứa recordedAt (yêu cầu của partitioned table Postgres).
model AttendanceLog {
  id              String           @default(uuid()) @db.Uuid
  orgId           String           @db.Uuid
  employeeId      String           @db.Uuid
  recordedAt      DateTime
  type            AttendanceType   @default(UNKNOWN)
  source          AttendanceSource
  worksiteId      String?          @db.Uuid
  lat             Float?
  lng             Float?
  accuracy        Float?
  locationSuspect Boolean          @default(false)
  faceScore       Float?
  photoKey        String?
  deviceId        String?          @db.Uuid
  note            String?
  createdById     String?          @db.Uuid
  createdAt       DateTime         @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@id([recordedAt, id])
  @@unique([employeeId, recordedAt, source])
  @@index([orgId, recordedAt])
  @@index([employeeId, recordedAt])
}

model TimesheetDay {
  id           String          @id @default(uuid()) @db.Uuid
  orgId        String          @db.Uuid
  employeeId   String          @db.Uuid
  date         DateTime        @db.Date
  shiftId      String?         @db.Uuid
  firstIn      DateTime?
  lastOut      DateTime?
  status       TimesheetStatus @default(NOT_SCHEDULED)
  lateMinutes  Int             @default(0)
  earlyMinutes Int             @default(0)
  workMinutes  Int             @default(0)
  otMinutes    Int             @default(0)
  /// HR sửa tay → khóa, recalc tự động KHÔNG ghi đè cho tới khi reset
  locked       Boolean         @default(false)
  /// Ghi chú khi HR sửa/khóa công
  note         String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employee Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([orgId, date])
}

model AttendanceCorrection {
  id           String           @id @default(uuid()) @db.Uuid
  orgId        String           @db.Uuid
  employeeId   String           @db.Uuid
  date         DateTime         @db.Date
  requestedIn  DateTime?
  requestedOut DateTime?
  reason       String
  status       CorrectionStatus @default(PENDING)
  createdById  String?          @db.Uuid
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employee Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([orgId, employeeId, date])
  @@index([orgId, status])
}

// ============================================================
// HRM — Face check-in 1:1 (Phase 5)
// ============================================================

model FaceProfile {
  id         String   @id @default(uuid()) @db.Uuid
  orgId      String   @db.Uuid
  employeeId String   @unique @db.Uuid
  /// Mảng embedding (mỗi ảnh enroll 1 vector số thực) — Json
  embeddings Json
  /// Key ảnh enroll trên object storage
  photoKeys  String[]
  enrolledAt DateTime @default(now())
  updatedBy  String?  @db.Uuid
  updatedAt  DateTime @updatedAt

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employee Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([orgId])
}
