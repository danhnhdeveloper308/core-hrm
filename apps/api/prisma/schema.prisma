generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BANNED
}

enum OAuthProvider {
  GOOGLE
}

enum VerificationType {
  EMAIL_VERIFY
  PASSWORD_RESET
  LOGIN_OTP
  INVITE
}

model User {
  id              String     @id @default(uuid()) @db.Uuid
  /// Luôn lưu lowercase — normalize ở zod schema trước khi vào DB
  email           String     @unique
  /// Null với user chỉ đăng nhập qua OAuth
  passwordHash    String?
  name            String
  avatarUrl       String?
  status          UserStatus @default(ACTIVE)
  emailVerifiedAt DateTime?
  /// TOTP secret đã mã hoá AES-256-GCM bằng TOTP_ENCRYPTION_KEY
  totpSecret      String?
  totpEnabled     Boolean    @default(false)
  /// Null = platform admin (không thuộc tenant nào)
  orgId           String?    @db.Uuid
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  org           Organization?  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  roles         UserRole[]
  sessions      Session[]
  devices       Device[]
  oauthAccounts OAuthAccount[]
  recoveryCodes RecoveryCode[]

  @@index([orgId])
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  /// Role hệ thống (SUPER_ADMIN/ADMIN/USER) — không sửa tên, không xoá
  isSystem    Boolean  @default(false)
  /// Null = role platform; có giá trị = role nội bộ 1 org (ORG_ADMIN, HR_MANAGER...)
  orgId       String?  @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org         Organization?    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  users       UserRole[]

  @@unique([orgId, name])
  @@index([orgId])
}

model Permission {
  id          String  @id @default(uuid()) @db.Uuid
  /// Format `resource:action`, seed từ @repo/shared
  name        String  @unique
  description String?

  roles RolePermission[]
}

model RolePermission {
  roleId       String @db.Uuid
  permissionId String @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserRole {
  userId String @db.Uuid
  roleId String @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model Session {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  /// sha256(refresh token) — không bao giờ lưu raw token
  refreshTokenHash String    @unique
  deviceId         String?   @db.Uuid
  ip               String?
  userAgent        String?
  lastActiveAt     DateTime  @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?
  revokedReason    String?
  createdAt        DateTime  @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  device Device? @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model Device {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  /// sha256(userAgent + platform) — nhận diện lại thiết bị giữa các session
  fingerprint      String
  /// Tên thân thiện, vd "Chrome on macOS"
  name             String
  firstSeenAt      DateTime  @default(now())
  lastSeenAt       DateTime  @default(now())
  trusted          Boolean   @default(false)
  /// sha256(token trong cookie trusted_device) — "ghi nhớ thiết bị" skip 2FA
  trustedTokenHash String?
  trustedUntil     DateTime?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions Session[]

  @@unique([userId, fingerprint])
}

model OAuthAccount {
  id                String        @id @default(uuid()) @db.Uuid
  userId            String        @db.Uuid
  provider          OAuthProvider
  providerAccountId String
  email             String?
  createdAt         DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  id         String           @id @default(uuid()) @db.Uuid
  /// Email nhận OTP
  identifier String
  codeHash   String
  type       VerificationType
  expiresAt  DateTime
  consumedAt DateTime?
  /// Số lần nhập sai — quá 5 thì vô hiệu
  attempts   Int              @default(0)
  createdAt  DateTime         @default(now())

  @@index([identifier, type])
}

model RecoveryCode {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String?  @db.Uuid
  actorEmail String?
  /// Dạng `resource.action`, vd `user.update`
  action     String
  resource   String
  resourceId String?
  ip         String?
  userAgent  String?
  /// Diff/context — đã redact password|token|secret|otp trước khi ghi
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([actorId, createdAt(sort: Desc)])
  @@index([resource, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc), id])
}

// ============================================================
// HRM — Multi-tenant & cơ cấu tổ chức (Phase 1)
// ============================================================

enum OrgStatus {
  ACTIVE
  SUSPENDED
}

model Organization {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  slug      String    @unique
  status    OrgStatus @default(ACTIVE)
  timezone  String    @default("Asia/Ho_Chi_Minh")
  settings  Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  users        User[]
  roles        Role[]
  orgUnitTypes OrgUnitType[]
  orgUnits     OrgUnit[]
  positions    Position[]
  worksites    Worksite[]
}

/// Loại đơn vị trong cây tổ chức — mỗi org tự định nghĩa (TAP_DOAN, NHA_MAY...)
model OrgUnitType {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @db.Uuid
  code      String
  name      String
  /// Gợi ý thứ tự tầng cho UI + resolve approver — cây KHÔNG ép đúng rank
  rank      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  units OrgUnit[]

  @@unique([orgId, code])
}

model OrgUnit {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @db.Uuid
  parentId  String?  @db.Uuid
  typeId    String   @db.Uuid
  name      String
  code      String
  /// Materialized path "/rootId/.../selfId/" — query subtree bằng startsWith
  path      String
  /// Employee.id — FK gắn ở Phase 2 khi có model Employee
  managerId String?  @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parent   OrgUnit?     @relation("OrgUnitTree", fields: [parentId], references: [id], onDelete: Restrict)
  children OrgUnit[]    @relation("OrgUnitTree")
  type     OrgUnitType  @relation(fields: [typeId], references: [id], onDelete: Restrict)

  @@unique([orgId, code])
  @@index([orgId, path])
  @@index([parentId])
}

model Position {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @db.Uuid
  name      String
  code      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, code])
}

model Worksite {
  id              String   @id @default(uuid()) @db.Uuid
  orgId           String   @db.Uuid
  name            String
  address         String?
  lat             Float
  lng             Float
  radiusM         Int      @default(100)
  requireFace     Boolean  @default(false)
  requireLocation Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}
