# ============================================================
# BACKEND (apps/api) — biến môi trường PRODUCTION
# Copy thành .env (hoặc nhập vào dashboard nền tảng). KHÔNG commit giá trị thật.
# Bắt buộc = phải có; còn lại có default an toàn.
# ============================================================

# ----- App -----
NODE_ENV=production
# Cảng nội bộ. Railway/Render/Fly tự inject PORT và app sẽ ưu tiên PORT đó.
API_PORT=8001
API_GLOBAL_PREFIX=api
# Origin FE được phép gọi API (CORS) — PHẢI đúng origin FE, không dùng '*'.
# Nhiều origin ngăn cách bằng dấu phẩy.
CORS_ORIGINS=https://your-frontend.vercel.app
# FE & BE KHÁC domain (Vercel + Railway/Render) → ĐỂ TRỐNG COOKIE_DOMAIN
# (cookie host-only của BE) và đặt COOKIE_SAMESITE=none.
# Nếu cùng registrable domain (app./api.) thì COOKIE_DOMAIN=.example.com + SAMESITE=lax.
COOKIE_DOMAIN=
# lax = cùng site | none = khác domain (BẮT BUỘC HTTPS). Khác domain → none.
COOKIE_SAMESITE=none

# ----- Database (Neon Postgres) — BẮT BUỘC -----
# App runtime: dùng chuỗi POOLED (…-pooler.…). sslmode=require bắt buộc với Neon.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
# (Tuỳ chọn nhưng KHUYẾN NGHỊ cho migrate) chuỗi DIRECT/UNPOOLED (host KHÔNG có '-pooler').
# Các script db:*:prod chạy migrate bằng URL này nếu có (pooler PgBouncer dễ lỗi advisory lock).
DIRECT_DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# ----- Redis (BullMQ + socket.io adapter) — BẮT BUỘC -----
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
# Upstash / Redis serverless yêu cầu TLS → true. Railway/Render private network → false.
REDIS_TLS=true

# ----- Auth / Security — BẮT BUỘC -----
# Tạo bằng: openssl rand -hex 48
JWT_ACCESS_SECRET=change_me_min_32_chars________________________
JWT_REFRESH_SECRET=change_me_min_32_chars________________________
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d
OTP_TTL_SECONDS=300
TOTP_ISSUER=HRM
# 64 ký tự hex (32 bytes): openssl rand -hex 32
TOTP_ENCRYPTION_KEY=change_me_64_hex_chars__________________________________________

# ----- Seed admin (chạy `pnpm db:seed` 1 lần) -----
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeThisStrongPassw0rd!

# ----- Mail (Brevo HTTP API ưu tiên → SMTP → console) -----
# KHUYẾN NGHỊ: đặt BREVO_API_KEY (HTTP API ổn định hơn SMTP, ít bị chặn).
BREVO_API_KEY=
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM_NAME=HRM System
# PHẢI là sender thuộc DOMAIN đã verify trong Brevo. TUYỆT ĐỐI KHÔNG dùng gmail/
# yahoo/outlook… (bị từ chối/spam do DMARC → email mời, OTP không tới được).
MAIL_FROM_ADDRESS=no-reply@congty.com

# ----- URL FE (link trong email + đích redirect OAuth/2FA) -----
NEXT_PUBLIC_APP_URL=https://your-frontend.vercel.app

# ----- Google OAuth (tuỳ chọn) -----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Callback trỏ về BE; khai báo y hệt trong Google Cloud Console.
GOOGLE_CALLBACK_URL=https://your-api.up.railway.app/api/auth/google/callback

# ----- Object storage S3-compatible (PROD: Cloudflare R2 / AWS S3 / Backblaze B2) -----
# Ví dụ Cloudflare R2:
S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=hrm
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_FORCE_PATH_STYLE=true
# Origin public để ký signed URL (R2 custom domain / S3 website). Bỏ trống = dùng S3_ENDPOINT.
S3_PUBLIC_URL=

# ----- FCM push (tuỳ chọn — thiếu thì chỉ in-app/email) -----
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Giữ \n escape trong 1 dòng, bọc nháy kép
FIREBASE_PRIVATE_KEY=

# ----- Face check-in (tuỳ chọn) -----
FACE_MATCH_THRESHOLD=0.55
FACE_ANTISPOOF_THRESHOLD=0.5
FACE_MODELS_PATH=./models
FACE_ENROLL_MIN_SCORE=0.8
# Tự tải model (~12MB) khi thiếu lúc khởi động → KHÔNG cần chạy script thủ công.
# Để true cho deploy nhanh (Render/Railway/Fly...). Tắt nếu đã build sẵn model vào image.
FACE_MODELS_AUTODOWNLOAD=true
FACE_MODELS_BASE_URL=https://vladmandic.github.io/human-models/models
