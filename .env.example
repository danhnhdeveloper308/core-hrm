# ===== Production deploy (docker-compose.prod.yml) =====
# Domain đã trỏ DNS về server — Caddy tự xin chứng chỉ Let's Encrypt.
# Mọi URL public (CORS, OAuth callback, NEXT_PUBLIC_*) tự suy ra từ DOMAIN.
# Production BẮT BUỘC đặt REDIS_PASSWORD (ở section Redis phía trên).
DOMAIN=app.example.com

# ===== Storage (S3-compatible — dev dùng MinIO trong docker-compose) =====
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=hrm
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio_secret
S3_FORCE_PATH_STYLE=true
# Origin public cho signed URL (prod: https://DOMAIN/storage) — trống thì dùng S3_ENDPOINT
S3_PUBLIC_URL=

# ===== Face check-in 1:1 (@vladmandic/human) =====
# Ngưỡng khớp theo metric similarity của Human (faceres): cùng người ~0.6+, khác người ~0.3
FACE_MATCH_THRESHOLD=0.55
FACE_ANTISPOOF_THRESHOLD=0.5
FACE_MODELS_PATH=./models
FACE_ENROLL_MIN_SCORE=0.8
