# ===== Postgres (local docker) =====
POSTGRES_USER=hrm
POSTGRES_PASSWORD=hrm_secret
POSTGRES_DB=hrm_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://hrm:hrm_secret@localhost:5432/hrm_db?schema=public

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Bật TLS khi dùng Redis serverless (vd Upstash). Local/Docker để false.
REDIS_TLS=false

# ===== API =====
API_PORT=8001
API_GLOBAL_PREFIX=api
CORS_ORIGINS=http://localhost:3000
COOKIE_DOMAIN=localhost
# lax (mặc định, cùng site) | none (FE/BE khác domain — bắt buộc HTTPS) | strict
COOKIE_SAMESITE=lax
NODE_ENV=development

# ===== Auth / Security =====
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars________
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars_______
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d
OTP_TTL_SECONDS=300
TOTP_ISSUER=HRM
# 32 bytes hex (64 ký tự) — tạo bằng: openssl rand -hex 32
TOTP_ENCRYPTION_KEY=change_me_64_hex_chars__________________________________________

# ===== Seed (pnpm db:seed) =====
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin12345

# ===== Mail — ưu tiên: BREVO_API_KEY (HTTP API) → MAIL_HOST (SMTP) → console (dev) =====
# API key xkeysib-... tại Brevo dashboard → Settings → API Keys.
# LƯU Ý deliverability: MAIL_FROM_ADDRESS phải là sender đã verify trong Brevo;
# dùng địa chỉ @gmail.com làm From sẽ fail DMARC → mail vào Spam.
BREVO_API_KEY=
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM_NAME="HRM System"
MAIL_FROM_ADDRESS=no-reply@example.com

# ===== Google OAuth =====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8001/api/auth/google/callback

# ===== Frontend =====
NEXT_PUBLIC_API_URL=http://localhost:8001/api
NEXT_PUBLIC_WS_URL=http://localhost:8001
NEXT_PUBLIC_APP_URL=http://localhost:3000

